# ---------------------------------------------------------------------------
# AuraAI environment configuration
# Copy to `.env` and fill in the values. Never commit the populated `.env`.
# ---------------------------------------------------------------------------

# --- Application ---
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Server ---
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# --- YouCam (Perfect Corp) API ---
# YOUCAM_SECRET_KEY is the RSA public key (PEM or bare base64) used to build the
# auth id_token. Depending on your account, the File/Task host may be
# `https://yce-api-01.makeupar.com` instead of perfectcorp.com — set accordingly.
YOUCAM_API_KEY=
YOUCAM_SECRET_KEY=
YOUCAM_BASE_URL=https://yce-api-01.perfectcorp.com
# Optional tuning (defaults shown): timeouts, retries, polling, rate limit.
# YOUCAM_MAX_RETRIES=4
# YOUCAM_POLL_INTERVAL_SECONDS=2.0
# YOUCAM_POLL_TIMEOUT_SECONDS=120.0
# YOUCAM_MAX_CONCURRENT_REQUESTS=8

# --- LLM provider ---
# "auto" prefers Groq when GROQ_API_KEY is set, else Gemini.
LLM_PROVIDER=auto

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (alternative)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=aura-uploads

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=3600

# --- Agent ---
AGENT_MAX_ITERATIONS=12
AGENT_RECURSION_LIMIT=25

# --- Authentication (Clerk) ---
# Set AUTH_REQUIRED=true in production. Leave false for local demo (anonymous).
AUTH_REQUIRED=false
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Issuer, e.g. https://your-app.clerk.accounts.dev ; JWKS is derived from it.
CLERK_ISSUER=
# Optional explicit override; otherwise <issuer>/.well-known/jwks.json.
# CLERK_JWKS_URL=
# Your frontend origins (authorized parties), e.g. ["https://app.aura.ai"].
CLERK_AUTHORIZED_PARTIES=[]

# --- Security ---
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=false            # enable only when served over HTTPS
MAX_UPLOAD_BYTES=10485760     # 10 MB
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_ENABLED=true
VIRUS_SCAN_ENABLED=false
# CLAMAV_HOST=clamav
# CLAMAV_PORT=3310

# --- Privacy / storage ---
SIGNED_URL_TTL_SECONDS=3600
IMAGE_RETENTION_DAYS=30
CONSENT_REQUIRED=true

# --- Observability (optional) ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=aura-backend
METRICS_ENABLED=true

# --- Frontend (Next.js public) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Set to enable Clerk auth on the frontend (leave blank for Demo Mode).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_USE_MOCK=false
